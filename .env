# ─── Lunch Money Ruby ─────────────────────────────────────────────────────────
#
# Default environment variables. Loaded by dotenv on startup.
#
# To override, copy to .env.local and fill in real values:
#   cp .env .env.local
#
# Load order: .env.local takes precedence over .env (see bin/lunchmoney).
# .env.local is gitignored — never commit secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────────────────
# Lunch Money API access token.
# Obtain from: https://my.lunchmoney.app/developers
# Can also be set via: lunchmoney login <TOKEN>
LUNCHMONEY_API_TOKEN=your_token_here

# ── Cache ─────────────────────────────────────────────────────────────────────
# Path to the SQLite cache database. Stores API responses locally for
# faster lookups and offline resolution (categories, tags, accounts, etc.).
# Supports ~ for home directory expansion.
LUNCHMONEY_CACHE_DB_PATH=~/.config/lunchmoney/cache.sqlite3

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: debug, info, warn, error, fatal
# Default: off (no logging). Set to "debug" to see HTTP requests/SQL queries.
# Can also be set per-invocation: lunchmoney --log-level debug ...
# LUNCHMONEY_LOG_LEVEL=

# Log output destination: stderr (default), stdout, or an absolute file path.
# Examples: stderr, stdout, /tmp/lunchmoney.log
# LUNCHMONEY_LOG_OUTPUT=
